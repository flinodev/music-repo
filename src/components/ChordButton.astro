---
interface Props {
  name: string;
}

const { name } = Astro.props;

// Mapeo de nombres de acordes a títulos completos
const chordMap: Record<string, { title: string; shorthand: string }> = {
  // Acordes Mayores
  doMa: { title: "Do Mayor", shorthand: "Do M" },
  reMa: { title: "Re Mayor", shorthand: "Re M" },
  miMa: { title: "Mi Mayor", shorthand: "Mi M" },
  faMa: { title: "Fa Mayor", shorthand: "Fa M" },
  solMa: { title: "Sol Mayor", shorthand: "Sol M" },
  laMa: { title: "La Mayor", shorthand: "La M" },
  siMa: { title: "Si Mayor", shorthand: "Si M" },

  // Acordes menores
  dome: { title: "Do menor", shorthand: "Do m" },
  reme: { title: "Re menor", shorthand: "Re m" },
  mime: { title: "Mi menor", shorthand: "Mi m" },
  fame: { title: "Fa menor", shorthand: "Fa m" },
  solme: { title: "Sol menor", shorthand: "Sol m" },
  lame: { title: "La menor", shorthand: "La m" },
  sime: { title: "Si menor", shorthand: "Si m" },

  // Acordes Sostenidos Mayores
  dososMa: { title: "Do Sostenido Mayor", shorthand: "Do# M" },
  resosMa: { title: "Re Sostenido Mayor", shorthand: "Re# M" },
  fasosMa: { title: "Fa Sostenido Mayor", shorthand: "Fa# M" },
  solsosMa: { title: "Sol Sostenido Mayor", shorthand: "Sol# M" },
  lasosMa: { title: "La Sostenido Mayor", shorthand: "La# M" },

  // Acordes Sostenidos menores
  dososme: { title: "Do Sostenido menor", shorthand: "Do# m" },
  resosme: { title: "Re Sostenido menor", shorthand: "Re# m" },
  fasosme: { title: "Fa Sostenido menor", shorthand: "Fa# m" },
  solsosme: { title: "Sol Sostenido menor", shorthand: "Sol# m" },
  lasosme: { title: "La Sostenido menor", shorthand: "La# m" },

  // Acordes Siete
  do7: { title: "Do 7", shorthand: "Do 7" },
  re7: { title: "Re 7", shorthand: "Re 7" },
  mi7: { title: "Mi 7", shorthand: "Mi 7" },
  fa7: { title: "Fa 7", shorthand: "Fa 7" },
  sol7: { title: "Sol 7", shorthand: "Sol 7" },
  la7: { title: "La 7", shorthand: "La 7" },
  si7: { title: "Si 7", shorthand: "Si 7" },

  // Acordes Sostenidos Siete
  dosos7: { title: "Do Sostenido 7", shorthand: "Do# 7" },
  resos7: { title: "Re Sostenido 7", shorthand: "Re# 7" },
  fasos7: { title: "Fa Sostenido 7", shorthand: "Fa# 7" },
  solsos7: { title: "Sol Sostenido 7", shorthand: "Sol# 7" },
  lasos7: { title: "La Sostenido 7", shorthand: "La# 7" },
};

const chord = chordMap[name];

if (!chord) {
  throw new Error(`Acorde "${name}" no encontrado. Verifica el nombre del acorde.`);
}

// ID único para el dialog
const dialogId = `chord-dialog-${name}`;
---

<span class="chord-button-wrapper">
  <button class="chord-button" data-dialog-id={dialogId}>
    {chord.shorthand}
  </button>

  <dialog id={dialogId} class="chord-dialog">
    <div class="chord-dialog-content">
      <div class="chord-dialog-header">
        <div class="chord-dialog-title">{chord.shorthand}</div>
        <button class="chord-dialog-close" aria-label="Cerrar">✕</button>
      </div>
      <img
        src={`/images/chords/${name}.png`}
        alt={chord.title}
        class="chord-dialog-image"
      />
    </div>
  </dialog>
</span>

<style>
  .chord-button-wrapper {
    display: inline-block;
  }

  .chord-button {
    background-color: #3b82f6;
    color: white;
    border: none;
    padding: 0.5rem 1rem;
    border-radius: 0.5rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s;
    font-family: inherit;
  }

  .chord-button:hover {
    background-color: #2563eb;
  }

  .chord-button:active {
    transform: scale(0.98);
  }

  .chord-dialog {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border: none;
    border-radius: 1rem;
    padding: 0;
    max-width: 90vw;
    max-height: 90vh;
    margin: 0;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
  }

  .chord-dialog::backdrop {
    background-color: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }

  .chord-dialog-content {
    padding: 1.5rem;
  }

  .chord-dialog-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #e5e7eb;
  }

  .chord-dialog-title {
    margin: 0;
    font-size: 1.875rem;
    font-weight: 700;
    color: #111827;
  }

  .chord-dialog-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: #6b7280;
    padding: 0.25rem 0.5rem;
    line-height: 1;
    border-radius: 0.25rem;
    transition: background-color 0.2s;
  }

  .chord-dialog-close:hover {
    background-color: #f3f4f6;
    color: #111827;
  }

  .chord-dialog-image {
    width: 100%;
    height: auto;
    border-radius: 0.5rem;
  }

  /* Estilos para mobile - modal más grande */
  @media (max-width: 768px) {
    .chord-dialog {
      max-width: 95vw;
      max-height: 85vh;
      width: 95vw;
    }

    .chord-dialog-content {
      padding: 1rem;
    }

    .chord-dialog-title {
      font-size: 1.25rem;
    }

    .chord-dialog-image {
      max-height: 70vh;
      object-fit: contain;
    }
  }

  /* Pantallas muy pequeñas - aprovechar aún más espacio */
  @media (max-width: 480px) {
    .chord-dialog {
      max-width: 98vw;
      width: 98vw;
      border-radius: 0.75rem;
    }
  }
</style>

<script>
  // Manejadores de eventos para abrir/cerrar diálogos
  document.addEventListener('DOMContentLoaded', () => {
    // Abrir dialog al hacer click en el botón
    document.querySelectorAll('.chord-button').forEach(button => {
      button.addEventListener('click', () => {
        const dialogId = button.getAttribute('data-dialog-id');
        if (dialogId) {
          const dialog = document.getElementById(dialogId) as HTMLDialogElement;
          if (dialog) {
            dialog.showModal();
          }
        }
      });
    });

    // Cerrar dialog con el botón de cerrar
    document.querySelectorAll('.chord-dialog-close').forEach(closeBtn => {
      closeBtn.addEventListener('click', () => {
        const dialog = closeBtn.closest('dialog') as HTMLDialogElement;
        if (dialog) {
          dialog.close();
        }
      });
    });

    // Cerrar dialog al hacer click fuera del contenido
    document.querySelectorAll('.chord-dialog').forEach(dialog => {
      dialog.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        if (target.tagName === 'DIALOG') {
          (target as HTMLDialogElement).close();
        }
      });
    });

    // Cerrar dialog con la tecla Escape (ya está integrado en <dialog>)
  });
</script>
